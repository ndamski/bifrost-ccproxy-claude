{
  "$schema": "https://www.getbifrost.ai/schema",
  "providers": {
    "cerebras": {
      "keys": [
        {
          "name": "cerebras-key",
          "value": "YOUR_CEREBRAS_KEY_HERE",
          "models": ["gpt-oss-120b"],
          "weight": 1.0
        }
      ]
    },
    "gemini": {
      "keys": [
        {
          "name": "gemini-key",
          "value": "YOUR_GEMINI_KEY_HERE",
          "models": ["gemini-2.5-flash", "gemini-2.5-flash-lite"],
          "weight": 1.0
        }
      ]
    },
    "openrouter": {
      "keys": [
        {
          "name": "openrouter-key",
          "value": "YOUR_OPENROUTER_KEY_HERE",
          "models": [
            "z-ai/glm-4.7-flash",
            "xiaomi/mimo-v2-flash",
            "google/gemini-2.5-flash-lite",
            "deepseek/deepseek-v3.2"
          ],
          "weight": 1.0
        }
      ]
    },
    "mistral": {
      "keys": [
        {
          "name": "mistral-key",
          "value": "YOUR_MISTRAL_KEY_HERE",
          "models": ["mistral-small-latest"],
          "weight": 1.0
        }
      ]
    }
  },
  "config_store": {
    "enabled": true,
    "type": "sqlite",
    "config": {
      "path": "./config.db"
    }
  }
}
